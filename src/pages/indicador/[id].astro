---
import Base from '../../layouts/Base.astro';
import LineChart from '../../components/LineChart.astro';
import LiveTrm from '../../components/LiveTrm.astro';
import { indicadores, getIndicador, statsPorMandato, fmt } from '../../lib/data.js';

export function getStaticPaths() {
  return indicadores.map((ind) => ({ params: { id: ind.id } }));
}

const { id } = Astro.params;
const ind = getIndicador(id);
const stats = statsPorMandato(ind).filter((s) => !s.sinDatos);
const site = Astro.site?.href ?? 'https://colombiaendatos.co/';
const puntos = ind.serie.filter((p) => p.valor != null);
// Dataset: aprovecha los rich results de datasets de Google; encaja con la naturaleza del sitio.
const jsonLd = [
  { '@context': 'https://schema.org', '@type': 'Dataset',
    name: ind.nombre, description: ind.descripcion, url: `${site}indicador/${ind.id}`,
    inLanguage: 'es-CO', license: 'https://creativecommons.org/publicdomain/zero/1.0/',
    isAccessibleForFree: true,
    ...(puntos.length ? { temporalCoverage: `${puntos[0].fecha}/${puntos.at(-1).fecha}` } : {}),
    ...(ind.fuente ? { creator: { '@type': 'Organization', name: ind.fuente, ...(ind.fuenteUrl ? { url: ind.fuenteUrl } : {}) } } : {}),
    publisher: { '@type': 'Organization', name: 'Colombia en Datos', url: site } },
  { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Colombia en Datos', item: site },
    { '@type': 'ListItem', position: 2, name: ind.nombre, item: `${site}indicador/${ind.id}` },
  ] },
];
// Para el delta: si el indicador es "menor mejor", una baja (delta<0) es buena.
const claseDelta = (delta) => {
  if (delta === 0) return '';
  const sube = delta > 0;
  const bueno = ind.mejorEs === 'menor' ? !sube : sube;
  return bueno ? 'down' : 'up';
};
---

<Base title={ind.nombre} descripcion={ind.descripcion} jsonLd={jsonLd}>
  <a href="/" class="muted" style="font-size:.9rem;">← Todos los indicadores</a>
  <h1 style="margin-top:12px;">{ind.nombre}</h1>
  <p class="muted">{ind.descripcion}</p>
  {!ind.verificado && (
    <p><span class="badge">datos semilla</span>
      <span class="muted" style="font-size:.85rem;"> {ind.nota}</span></p>
  )}
  {ind.apiLive && (
    <div style="margin:16px 0;">
      <LiveTrm fallback={ind.serie.filter((p) => p.valor != null).at(-1)?.valor} />
    </div>
  )}

  <div class="card" style="margin-top:20px;">
    {ind.serie.filter((p) => p.valor != null).length >= 2
      ? <LineChart indicador={ind} />
      : <p class="muted" style="margin:0;">Serie en carga desde fuentes oficiales. Vuelve pronto.</p>}
  </div>

  {ind.serie.some((p) => p.nota) && (
    <ul class="notas-punto">
      {ind.serie.filter((p) => p.nota).map((p) => (
        <li><span class="anillo" aria-hidden="true"></span><strong>{p.fecha.slice(0, 4)}:</strong> {p.nota}</li>
      ))}
    </ul>
  )}

  <h2>Por mandato</h2>
  <table>
    <thead>
      <tr>
        <th>Mandato</th><th>Inicio</th><th>Fin</th><th>Promedio</th><th>Cambio</th>
      </tr>
    </thead>
    <tbody>
      {stats.map((s) => (
        <tr>
          <td>{s.mandato.nombre}</td>
          <td>{fmt(s.primero, ind.unidad)}</td>
          <td>{fmt(s.ultimo, ind.unidad)}</td>
          <td>{fmt(s.promedio, ind.unidad)}</td>
          <td class={claseDelta(s.delta)}>
            {s.delta > 0 ? '▲' : s.delta < 0 ? '▼' : ''} {fmt(Math.abs(s.delta), ind.unidad)}
            {s.deltaPct != null && ` (${s.deltaPct > 0 ? '+' : ''}${s.deltaPct.toFixed(0)}%)`}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="muted" style="font-size:.85rem;margin-top:8px;">
    "Cambio" compara el primer y último dato disponible dentro del mandato.
    Verde = evolución favorable ({ind.mejorEs === 'menor' ? 'baja' : 'sube'}).
  </p>

  <p style="margin-top:24px;">
    <strong>Fuente:</strong> <a href={ind.fuenteUrl} target="_blank" rel="noopener">{ind.fuente}</a>
    · Frecuencia: {ind.frecuencia}
  </p>
</Base>

<style>
  /* Notas por-punto (cambios de metodología, datos parciales): anillo terracota igual que en la gráfica. */
  .notas-punto { list-style:none; margin:10px 0 0; padding:0; display:flex; flex-direction:column; gap:6px;
    font-size:.85rem; color:var(--muted); }
  .notas-punto li { display:flex; align-items:baseline; gap:8px; }
  .notas-punto strong { color:var(--ink); }
  .anillo { flex:none; width:9px; height:9px; border-radius:50%; background:var(--canvas);
    border:2.5px solid var(--primary); transform:translateY(1px); }
</style>
