---
// Valor "hoy" en vivo desde la API oficial (Socrata). Progresivo: si el fetch
// falla, queda el último valor conocido del build.
const { fallback } = Astro.props;
---
<p class="live" data-live-trm>
  <span class="dot" aria-hidden="true"></span>
  TRM hoy: <strong data-valor>{fallback ? `$${Math.round(fallback).toLocaleString('es-CO')}` : '—'}</strong>
  <span class="muted" data-fecha style="font-size:.82rem;"></span>
</p>

<script>
  document.addEventListener('astro:page-load', () => {
  const box = document.querySelector('[data-live-trm]');
  if (!box) return;
  const url = 'https://www.datos.gov.co/resource/32sa-8pi3.json?$order=vigenciadesde%20DESC&$limit=1';
  fetch(url)
    .then((r) => r.json())
    .then(([row]) => {
      if (!row) return;
      const v = Math.round(Number(row.valor)).toLocaleString('es-CO');
      const f = new Date(row.vigenciadesde).toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' });
      box.querySelector('[data-valor]').textContent = `$${v}`;
      box.querySelector('[data-fecha]').textContent = `· ${f} · fuente oficial en vivo`;
    })
    .catch(() => { box.querySelector('[data-fecha]').textContent = '· valor de último cierre'; });
  });
</script>

<style>
  .live {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--surface-1); border: 1px solid var(--border);
    border-radius: var(--radius-pill); padding: 8px 16px; font-size: .95rem;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--primary);
    box-shadow: 0 0 0 0 rgba(194,82,45,0.5); animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(194,82,45,0.5); }
    70% { box-shadow: 0 0 0 6px rgba(194,82,45,0); }
    100% { box-shadow: 0 0 0 0 rgba(194,82,45,0); }
  }
  @media (prefers-reduced-motion: reduce) { .dot { animation: none; } }
</style>
