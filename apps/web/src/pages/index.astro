---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { indicadores, mandatos } from '../lib/data.js';
---

<Base
  title=""
  descripcion="Los indicadores económicos de Colombia por mandato presidencial, con fuente oficial. Compara Uribe, Santos, Duque y Petro con datos, sin sesgo."
>
  <h1>Colombia en Datos</h1>
  <p class="muted" style="font-size:1.1rem;max-width:640px;">
    Los indicadores económicos de Colombia, organizados por mandato presidencial —
    de Uribe I (2002) a hoy. Cada dato con su fuente oficial. Sin sesgo, sin adjetivos.
  </p>

  <h2>Indicadores</h2>
  <div class="grid">
    {indicadores.map((ind) => (
      <a href={`/indicador/${ind.id}`} class="card" style="text-decoration:none;color:inherit;">
        <div style="display:flex;justify-content:space-between;align-items:start;gap:8px;">
          <strong>{ind.nombre}</strong>
          {!ind.verificado && <span class="badge">semilla</span>}
        </div>
        <p class="muted" style="font-size:.9rem;margin:8px 0 0;">{ind.descripcion}</p>
        <p class="muted" style="font-size:.8rem;margin:12px 0 0;">Fuente: {ind.fuente}</p>
      </a>
    ))}
  </div>

  <div style="margin-top:32px;">
    <Newsletter />
  </div>

  <h2>Mandatos</h2>
  <div class="grid">
    {mandatos.map((m) => (
      <div class="card" style={`border-left:4px solid ${m.color};`}>
        <strong>{m.nombre}</strong>
        <p class="muted" style="font-size:.85rem;margin:6px 0 0;">
          {m.presidente}<br />
          {m.inicio.slice(0, 4)}–{m.fin.slice(0, 4)}
        </p>
      </div>
    ))}
  </div>
</Base>
