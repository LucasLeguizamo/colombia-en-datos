---
import Base from '../../layouts/Base.astro';
import LineChart from '../../components/LineChart.astro';
import { indicadores, getIndicador, statsPorMandato, fmt } from '../../lib/data.js';

export function getStaticPaths() {
  return indicadores.map((ind) => ({ params: { id: ind.id } }));
}

const { id } = Astro.params;
const ind = getIndicador(id);
const stats = statsPorMandato(ind).filter((s) => !s.sinDatos);
// Para el delta: si el indicador es "menor mejor", una baja (delta<0) es buena.
const claseDelta = (delta) => {
  if (delta === 0) return '';
  const sube = delta > 0;
  const bueno = ind.mejorEs === 'menor' ? !sube : sube;
  return bueno ? 'down' : 'up';
};
---

<Base title={ind.nombre} descripcion={ind.descripcion}>
  <a href="/" class="muted" style="font-size:.9rem;">← Todos los indicadores</a>
  <h1 style="margin-top:12px;">{ind.nombre}</h1>
  <p class="muted">{ind.descripcion}</p>
  {!ind.verificado && (
    <p><span class="badge">datos semilla</span>
      <span class="muted" style="font-size:.85rem;"> {ind.nota}</span></p>
  )}

  <div class="card" style="margin-top:20px;">
    <LineChart indicador={ind} />
  </div>

  <h2>Por mandato</h2>
  <table>
    <thead>
      <tr>
        <th>Mandato</th><th>Inicio</th><th>Fin</th><th>Promedio</th><th>Cambio</th>
      </tr>
    </thead>
    <tbody>
      {stats.map((s) => (
        <tr>
          <td>{s.mandato.nombre}</td>
          <td>{fmt(s.primero, ind.unidad)}</td>
          <td>{fmt(s.ultimo, ind.unidad)}</td>
          <td>{fmt(s.promedio, ind.unidad)}</td>
          <td class={claseDelta(s.delta)}>
            {s.delta > 0 ? '▲' : s.delta < 0 ? '▼' : ''} {fmt(Math.abs(s.delta), ind.unidad)}
            {s.deltaPct != null && ` (${s.deltaPct > 0 ? '+' : ''}${s.deltaPct.toFixed(0)}%)`}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="muted" style="font-size:.85rem;margin-top:8px;">
    "Cambio" compara el primer y último dato disponible dentro del mandato.
    Verde = evolución favorable ({ind.mejorEs === 'menor' ? 'baja' : 'sube'}).
  </p>

  <p style="margin-top:24px;">
    <strong>Fuente:</strong> <a href={ind.fuenteUrl} target="_blank" rel="noopener">{ind.fuente}</a>
    · Frecuencia: {ind.frecuencia}
  </p>
</Base>
