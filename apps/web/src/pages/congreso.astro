---
import Base from '../layouts/Base.astro';
import { congreso, getMandato, colorBloque } from '../lib/data.js';

const camara = (p) => p.camara ?? {};
const senado = (p) => p.senado ?? {};

// Barra de curules: segmentos proporcionales, ordenados por bloque y tamaño.
function segmentos(camaraOsenado) {
  const partidos = (camaraOsenado.partidos ?? [])
    .filter((x) => x.curules > 0)
    .sort((a, b) => (a.bloque === b.bloque ? b.curules - a.curules : a.bloque < b.bloque ? -1 : 1));
  const total = camaraOsenado.total ?? partidos.reduce((s, x) => s + x.curules, 0);
  return { partidos, total };
}
---

<Base
  title="Congreso por mandato"
  descripcion="Composición de Cámara y Senado por partido durante cada gobierno de Colombia, y si el presidente tenía mayoría o no."
>
  <h1>El Congreso de cada gobierno</h1>
  <p class="muted" style="max-width:640px;">
    Cámara y Senado por partido tras cada elección legislativa.
    <span style="color:#4A7C2E;">Verde</span> = bancada de gobierno,
    <span style="color:#B4341C;">rojo</span> = oposición,
    gris = independiente.
  </p>
  {!congreso.verificado && <p><span class="badge">datos en verificación</span></p>}

  {congreso.periodos.length === 0 && (
    <div class="card"><p class="muted" style="margin:0;">Datos en carga desde fuentes oficiales. Vuelve pronto.</p></div>
  )}

  {congreso.periodos.map((p) => {
    const m = getMandato(p.mandato);
    return (
      <section style="margin-bottom:48px;">
        <h2 style={`border-left:4px solid ${m?.color ?? '#888'};padding-left:12px;`}>
          {m?.nombre ?? p.mandato}
          <span class="muted" style="font-weight:400;font-size:1rem;"> · {m?.inicio.slice(0,4)}–{m?.fin.slice(0,4)}</span>
        </h2>
        {['senado', 'camara'].map((camara_key) => {
          const c = p[camara_key] ?? {};
          const { partidos, total } = segmentos(c);
          if (partidos.length === 0) return null;
          return (
            <div style="margin:16px 0;">
              <div style="display:flex;justify-content:space-between;font-size:.9rem;margin-bottom:6px;">
                <strong style="text-transform:capitalize;">{camara_key === 'camara' ? 'Cámara' : 'Senado'}</strong>
                <span class="muted">{total} curules</span>
              </div>
              <div style="display:flex;height:28px;border-radius:6px;overflow:hidden;border:1px solid var(--border);">
                {partidos.map((x) => (
                  <div
                    title={`${x.partido}: ${x.curules} (${x.bloque})`}
                    style={`width:${(x.curules / total) * 100}%;background:${colorBloque(x.bloque)};`}
                  ></div>
                ))}
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:4px 16px;margin-top:8px;font-size:.82rem;">
                {partidos.map((x) => (
                  <span class="muted">
                    <span style={`display:inline-block;width:9px;height:9px;border-radius:2px;background:${colorBloque(x.bloque)};margin-right:5px;`}></span>
                    {x.partido} <strong style="color:var(--ink);">{x.curules}</strong>
                  </span>
                ))}
              </div>
            </div>
          );
        })}
      </section>
    );
  })}

  {congreso.periodos.length > 0 && (
    <p class="muted" style="font-size:.85rem;">
      Fuentes: {congreso.fuentes.join(' · ')}. {congreso.nota}
    </p>
  )}
</Base>
