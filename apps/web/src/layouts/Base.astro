---
const { title, descripcion } = Astro.props;
const fullTitle = title ? `${title} · Colombia en Datos` : 'Colombia en Datos';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <meta property="og:title" content={fullTitle} />
    {descripcion && <meta property="og:description" content={descripcion} />}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🇨🇴</text></svg>" />
  </head>
  <body>
    <header>
      <a href="/" class="brand">🇨🇴 Colombia en Datos</a>
      <nav>
        <a href="/congreso">Congreso</a>
        <a href="/gabinete">Gabinete</a>
        <a href="/comparar">Comparar</a>
        <a href="https://github.com/LucasLeguizamo/colombia-en-datos" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Datos de fuentes oficiales (DANE, Banco de la República). Código MIT, datos CC0.
         Cada indicador enlaza su fuente. Sin sesgo, sin adjetivos.</p>
    </footer>
    <style is:global>
      /* Anthropic design system — warm parchment canvas, terracotta accent. */
      :root {
        --primary: #C2522D; --primary-hover: #A8421F; --on-primary: #ffffff;
        --ink: #1A1A18; --muted: #6B6B63;
        --canvas: #FAF9F7; --surface-1: #F2F0EC; --surface-2: #E8E5E0;
        --border: #D8D4CC; --accent-warm: #D4A574;
        --radius-md: 8px; --radius-lg: 16px; --radius-pill: 9999px;
        --shadow-card: 0 1px 2px rgba(26,26,24,0.06);
        --shadow-elevated: 0 4px 24px rgba(26,26,24,0.08);
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --sans: "Styrene A", "Styrene B", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; color: var(--ink); background: var(--canvas);
        font-family: var(--sans); font-size: 17px; line-height: 1.65; letter-spacing: -0.01em;
        -webkit-font-smoothing: antialiased;
      }
      header, footer { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
      main { max-width: 960px; margin: 0 auto; padding: 0 24px; padding-top: 64px; padding-bottom: 96px; }
      header {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border);
      }
      .brand { font-weight: 500; font-size: 1.15rem; text-decoration: none; color: var(--ink);
               letter-spacing: -0.02em; }
      nav a {
        margin-left: 24px; text-decoration: none; color: var(--muted); font-size: .95rem;
        transition: color 120ms var(--ease);
      }
      nav a:hover { color: var(--ink); }
      footer { border-top: 1px solid var(--border); margin-top: 64px; padding-top: 32px;
               padding-bottom: 64px; color: var(--muted); font-size: .9rem; max-width: 960px; }
      h1 { font-size: 52px; font-weight: 500; line-height: 1.08; letter-spacing: -0.03em; margin: 0 0 16px; }
      h2 { font-size: 1.5rem; font-weight: 500; letter-spacing: -0.02em; margin: 48px 0 16px; }
      p { margin: 0 0 16px; }
      a { color: var(--primary); text-decoration-thickness: 1px; text-underline-offset: 2px;
          transition: color 120ms var(--ease); }
      a:hover { color: var(--primary-hover); }
      :focus-visible { outline: 2px solid var(--primary); outline-offset: 2px; border-radius: var(--radius-md); }
      table { border-collapse: collapse; width: 100%; font-size: .95rem; margin-top: 16px; }
      th, td { text-align: right; padding: 12px 14px; border-bottom: 1px solid var(--border); }
      th:first-child, td:first-child { text-align: left; }
      thead th { color: var(--muted); font-weight: 500; font-size: .82rem;
                 text-transform: uppercase; letter-spacing: 0.04em; }
      .card {
        border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px;
        background: var(--canvas); box-shadow: var(--shadow-card);
        transition: box-shadow 240ms var(--ease), border-color 240ms var(--ease);
      }
      a.card:hover { box-shadow: var(--shadow-elevated); border-color: var(--accent-warm); }
      .grid { display: grid; gap: 24px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
      .muted { color: var(--muted); }
      .badge {
        display: inline-block; font-size: .72rem; padding: 3px 10px; border-radius: var(--radius-pill);
        background: rgba(212,165,116,0.24); color: #7A4A1E; font-weight: 500;
        letter-spacing: 0.01em;
      }
      /* Cambio favorable/desfavorable — semántica de dato, tonos cálidos. */
      .up { color: #B4341C; } .down { color: #4A7C2E; }
      @media (max-width: 640px) { h1 { font-size: 38px; } main { padding-top: 40px; } }
      @media (prefers-reduced-motion: reduce) {
        * { transition: none !important; animation: none !important; }
      }
    </style>
  </body>
</html>
