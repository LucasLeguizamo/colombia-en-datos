---
const { title, descripcion } = Astro.props;
const fullTitle = title ? `${title} · Colombia en Datos` : 'Colombia en Datos';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {descripcion && <meta name="description" content={descripcion} />}
    <meta property="og:title" content={fullTitle} />
    {descripcion && <meta property="og:description" content={descripcion} />}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🇨🇴</text></svg>" />
  </head>
  <body>
    <header>
      <a href="/" class="brand">🇨🇴 Colombia en Datos</a>
      <nav>
        <a href="/comparar">Comparar</a>
        <a href="https://github.com/Lucas-FullStackX/colombia-en-datos" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Datos de fuentes oficiales (DANE, Banco de la República). Código MIT, datos CC0.
         Cada indicador enlaza su fuente. Sin sesgo, sin adjetivos.</p>
    </footer>
    <style is:global>
      :root { --fg: #111827; --muted: #6b7280; --line: #e5e7eb; --bg: #ffffff; }
      * { box-sizing: border-box; }
      body {
        margin: 0; color: var(--fg); background: var(--bg);
        font-family: system-ui, -apple-system, sans-serif; line-height: 1.55;
      }
      header, main, footer { max-width: 980px; margin: 0 auto; padding: 0 20px; }
      header {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--line);
      }
      .brand { font-weight: 700; font-size: 1.1rem; text-decoration: none; color: var(--fg); }
      nav a { margin-left: 18px; text-decoration: none; color: var(--muted); font-size: .95rem; }
      nav a:hover { color: var(--fg); }
      main { padding-top: 32px; padding-bottom: 48px; }
      footer { border-top: 1px solid var(--line); padding-top: 20px; padding-bottom: 40px;
               color: var(--muted); font-size: .85rem; }
      h1 { font-size: 2rem; margin: 0 0 8px; }
      h2 { font-size: 1.3rem; margin: 32px 0 12px; }
      a { color: #2563eb; }
      table { border-collapse: collapse; width: 100%; font-size: .92rem; margin-top: 12px; }
      th, td { text-align: right; padding: 8px 10px; border-bottom: 1px solid var(--line); }
      th:first-child, td:first-child { text-align: left; }
      thead th { color: var(--muted); font-weight: 600; }
      .card { border: 1px solid var(--line); border-radius: 12px; padding: 20px; }
      .grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
      .muted { color: var(--muted); }
      .badge { display: inline-block; font-size: .72rem; padding: 2px 8px; border-radius: 999px;
               background: #fef3c7; color: #92400e; font-weight: 600; }
      .up { color: #dc2626; } .down { color: #16a34a; }
    </style>
  </body>
</html>
