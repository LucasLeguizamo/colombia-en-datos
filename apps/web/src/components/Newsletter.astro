---
// "El mes en 5 datos" — suscripción guardada en InsForge (tabla suscriptores).
// El anon key es público; el RLS solo permite INSERT, nadie lee la lista.
---
<form data-newsletter class="news">
  <div>
    <strong>El mes en 5 datos</strong>
    <p class="muted" style="margin:4px 0 0;font-size:.9rem;">
      Un correo al mes con los indicadores que se movieron. Sin spam.
    </p>
  </div>
  <div class="row">
    <input type="email" name="email" required placeholder="tu@correo.com" aria-label="Correo" />
    <button type="submit">Suscribirme</button>
  </div>
  <p data-msg class="muted" style="margin:0;font-size:.85rem;min-height:1.2em;" role="status" aria-live="polite"></p>
</form>

<script>
  import { createClient } from '@insforge/sdk';

  const insforge = createClient({
    baseUrl: import.meta.env.PUBLIC_INSFORGE_URL,
    anonKey: import.meta.env.PUBLIC_INSFORGE_ANON_KEY,
  });

  const form = document.querySelector('[data-newsletter]');
  const msg = form.querySelector('[data-msg]');
  const btn = form.querySelector('button');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.email.value.trim().toLowerCase();
    btn.disabled = true;
    msg.textContent = 'Enviando…';
    // Sin .select(): el RLS no expone SELECT, solo insertamos.
    const { error } = await insforge.database.from('suscriptores').insert([{ email }]);
    if (!error) {
      msg.textContent = '¡Listo! Quedaste suscrito.';
      form.reset();
    } else if (error.message?.match(/duplicate|unique|already/i)) {
      msg.textContent = 'Ese correo ya estaba suscrito.';
    } else {
      msg.textContent = 'No se pudo guardar. Intenta de nuevo.';
      btn.disabled = false;
    }
  });
</script>

<style>
  .news { border: 1px solid var(--border); border-radius: var(--radius-lg);
          padding: 24px; background: var(--surface-1); display: grid; gap: 14px; }
  .news .row { display: flex; gap: 8px; flex-wrap: wrap; }
  .news input {
    flex: 1 1 220px; padding: 10px 14px; font: inherit; color: var(--ink);
    background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-md);
  }
  .news input:focus-visible { outline: 2px solid var(--primary); outline-offset: 1px; }
  .news button {
    padding: 10px 20px; font: inherit; font-weight: 500; cursor: pointer;
    color: var(--on-primary); background: var(--primary); border: none;
    border-radius: var(--radius-md); transition: background 120ms var(--ease);
  }
  .news button:hover { background: var(--primary-hover); }
  .news button:disabled { opacity: .6; cursor: default; }
</style>
